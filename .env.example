# ═══════════════════════════════════════════════════════════════════
# Trix Audio Converter — Variáveis de Ambiente (Exemplo)
# Copie para .env e preencha os valores reais
# NUNCA versione o arquivo .env — apenas o .env.example
# ═══════════════════════════════════════════════════════════════════

# ── Servidor ──
# Porta que o backend Rust (Axum) vai escutar.
# Se a porta 3939 estiver ocupada, o app escolhe uma porta aleatória automaticamente.
PORT=3939
HOST=127.0.0.1

# ── API Token (Segurança) ──
# Se vazio, o app gera um token criptograficamente seguro automaticamente em runtime.
# Preencha apenas se quiser fixar um token específico para automação/testes.
API_TOKEN=

# ── GitHub Releases (para auto-update) ──
GITHUB_OWNER=damonio13
GITHUB_REPO=Trix-Audio-Converter

# ── Cloud Sync (opcional — funcionalidade futura) ──
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
# DROPBOX_APP_KEY=

# ── API Keys (opcional — para lookup externo de metadados) ──
# MUSICBRAINZ_USER_AGENT=TrixAudioConverter/1.0.0 (joaovmelo259@gmail.com)
# DISCOGS_TOKEN=

# ── Desenvolvimento ──
# VITE_API_URL=http://localhost:3939
# RUST_LOG=debug
